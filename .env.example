# Supabase Configuration (Backend)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Frontend (Next.js) — must use NEXT_PUBLIC_ prefix to be exposed to browser code
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Machine Learning Model Paths (backend)
DETECTOR_MODEL_PATH="models/detector.onnx"
EMBEDDER_MODEL_PATH="models/embedder.onnx"

# Backend runtime
ENVIRONMENT="development"          # development | production — gate debug logging, CORS strictness
BACKEND_PORT="8000"
ALLOWED_ORIGINS="http://localhost:3000"   # CORS allowlist; add your Vercel URL once deployed

# Matching / ML behavior
MATCH_THRESHOLD="0.65"             # placeholder — replace with your actual EER-calibrated value
EMBEDDING_VERSION="v1"             # must match the default in nose_prints.embedding_version

# Upload limits
MAX_FILE_SIZE_MB="8"
ALLOWED_UPLOAD_TYPES="image/jpeg,image/png,image/webp"

# Rate limiting
IDENTIFY_RATE_LIMIT="10/minute"    # applied specifically to /dogs/identify per Phase 2 spec
